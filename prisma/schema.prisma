generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Visa {
  id           String   @id @default(cuid())
  category     String
  name         String
  description  String
  price        String
  fee          String
  validity     String
  extendable   Boolean
  requirements String
  details      String   @default("{}")
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model User {
  id                      String             @id @db.Uuid
  email                   String             @unique
  name                    String?
  whatsapp                String?
  role                    String             @default("user")
  status                  String             @default("active")
  avatar                  String?
  address                 String?
  bio                     String?
  socials                 String?
  last_activity_at        DateTime?
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  notificationPreferences Json?              @default("{\"push\": true, \"email\": true, \"marketing\": false}")
  documents               Document[]
  notifications           Notification[]
  verification            Verification?
  arrivalCards            ArrivalCard[]
  conversations           Conversation[]
  invoices                Invoice[]
  payments                Payment[]
  pushSubscriptions       PushSubscription[]
  applications            VisaApplication[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityId   String?
  entityType String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

model VisaApplication {
  id                   String                @id @default(cuid())
  userId               String?               @map("user_id") @db.Uuid
  visaId               String
  visaName             String?
  status               String                @default("Pending")
  verificationId       String?
  slug                 String?               @unique @default(cuid())
  guestName            String?
  guestEmail           String?
  paymentMethod        String?
  customAmount         String?
  documents            Json?
  expiresAt            DateTime?
  appliedAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  attribution          Json?
  quantity             Int                   @default(1)
  applicationDocuments ApplicationDocument[]
  invoices             Invoice[]
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("visa_applications")
}

model Document {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  name      String
  url       String
  size      String   @default("0 KB")
  type      String   @default("application/pdf")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(cuid())
  userId     String?  @db.Uuid
  title      String
  message    String
  isRead     Boolean  @default(false)
  type       String   @default("info")
  actionLink String?
  actionText String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id             String    @id @default(cuid())
  userId         String?   @unique @db.Uuid
  fullName       String
  passportNumber String
  visaType       String
  issuedDate     DateTime
  status         String    @default("VALID")
  expiresAt      DateTime?
  slug           String    @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  address        String?
  nationality    String?
  photoUrl       String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompanyService {
  id          String   @id @default(cuid())
  category    String
  name        String
  price       String
  description String
  features    String[] @default([])
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Conversation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  status          String    @default("open")
  assignedAdminId String?   @map("assigned_admin_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  senderType     String
  message        String
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now()) @map("created_at")
  metadata       Json?        @default("{}")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model ApplicationDocument {
  id            String          @id @default(cuid())
  applicationId String          @map("application_id")
  fileName      String          @map("file_name")
  filePath      String          @map("file_path")
  fileType      String          @map("file_type")
  uploadedAt    DateTime        @default(now()) @map("uploaded_at")
  application   VisaApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_documents")
}

model EmailLog {
  id        String   @id @default(cuid())
  recipient String
  subject   String
  content   String
  status    String   @default("SENT")
  sentAt    DateTime @default(now()) @map("sent_at")

  @@map("email_logs")
}

model Invoice {
  id               String           @id @default(cuid())
  userId           String?          @db.Uuid
  applicationId    String?
  amount           Decimal          @db.Decimal(20, 2)
  currency         String           @default("IDR")
  status           PaymentStatus    @default(UNPAID)
  paymentMethod    String?
  paymentReference String?
  adminNotes       String?
  dueDate          DateTime?
  paidAt           DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  quantity         Int              @default(1)
  gatewayFee       Decimal?         @default(0) @db.Decimal(20, 2)
  pph23Amount      Decimal?         @default(0) @db.Decimal(20, 2)
  serviceFee       Decimal?         @default(0) @db.Decimal(20, 2)
  visaApplication  VisaApplication? @relation(fields: [applicationId], references: [id])
  user             User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments         Payment[]

  @@map("invoices")
}

model ArrivalCard {
  id             String   @id @default(cuid())
  userId         String?  @db.Uuid
  passportNumber String
  fullName       String
  arrivalDate    DateTime
  flightNumber   String?
  status         String   @default("PENDING")
  formData       Json
  documentUrl    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User?    @relation(fields: [userId], references: [id])

  @@map("arrival_cards")
}

model Payment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  transactionId   String?  @unique
  invoiceId       String?
  applicationId   String?  @map("application_id")
  userId          String?  @db.Uuid
  grossAmount     Decimal  @db.Decimal(20, 2)
  currency        String   @default("IDR")
  paymentType     String?
  status          String   @default("PENDING")
  snapToken       String?
  snapRedirectUrl String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  user            User?    @relation(fields: [userId], references: [id])

  @@map("payments")
}

model AIChangeRequest {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId       String   @unique @map("request_id")
  initiatedBy     String   @map("initiated_by")
  changeType      String   @map("change_type")
  pageCategory    String   @map("page_category")
  targetPage      String   @map("target_page")
  proposedChanges Json     @map("proposed_changes")
  riskScore       String?  @map("risk_score")
  impactForecast  Json?    @map("impact_forecast")
  modeStatus      String   @map("mode_status")
  currentState    String   @map("current_state")
  approvalId      String?  @map("approval_id")
  overrideFlag    Boolean  @default(false) @map("override_flag")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@map("ai_change_requests")
}

model AIExecutionLog {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId          String   @map("request_id")
  agentName          String   @map("agent_name")
  actionType         String   @map("action_type")
  snapshotBeforeId   String?  @map("snapshot_before_id")
  snapshotAfterId    String?  @map("snapshot_after_id")
  overrideFlag       Boolean  @default(false) @map("override_flag")
  executionTimestamp DateTime @default(now()) @map("execution_timestamp")
  status             String
  notes              String?

  @@map("ai_execution_logs")
}

model AIMasterMemory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memoryKey   String   @unique @map("memory_key")
  memoryValue Json     @map("memory_value")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("ai_master_memory")
}

model AIRiskLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scanType  String   @map("scan_type")
  findings  Json
  riskLevel String   @map("risk_level")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ai_risk_logs")
}

model AISnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId    String   @map("request_id")
  pagePath     String   @map("page_path")
  snapshotData Json     @map("snapshot_data")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ai_snapshots")
}

model AISystemState {
  id                 String    @id @default("singleton")
  mode               String    @default("normal")
  lastRiskScan       DateTime? @map("last_risk_scan")
  systemHealthStatus String    @default("healthy") @map("system_health_status")
  updatedAt          DateTime  @default(now()) @map("updated_at")

  @@map("ai_system_state")
}

model ChatConversation {
  id          String   @id @default(cuid())
  sessionId   String   @unique @map("session_id")
  messages    Json
  topic       String?
  isMasterCmd Boolean  @default(false) @map("is_master_cmd")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("chat_conversations")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model ImmigrationUpdate {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("Immigration")
  summary   String?
  image     String?
  slug      String   @unique
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("immigration_updates")
}

model MarketingLead {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  phone           String?
  visaType        String?
  status          String   @default("LEAD")
  attributionData Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("marketing_leads")
}

model KnowledgePage {
  id        String              @id @default(cuid())
  slug      String              @unique
  title     String
  content   Json
  pageType  String              @default("knowledge_article")
  category  String?
  metadata  Json?
  published Boolean             @default(false)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  authorId  String?             @map("author_id")
  quality   AIContentQuality?
  author    KnowledgeAuthor?    @relation(fields: [authorId], references: [id])
  sources   ImmigrationSource[] @relation("PageSources")

  @@map("knowledge_pages")
}

model AITopicHistory {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topicTitle      String    @map("topic_title")
  topicSlug       String    @unique @map("topic_slug")
  topicCluster    String    @map("topic_cluster")
  sourceAgent     String    @map("source_agent")
  status          String    @default("draft")
  confidenceScore Float?    @map("confidence_score")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  publishedAt     DateTime? @map("published_at")

  @@map("ai_topic_history")
}

model KnowledgeAuthor {
  id           String          @id @default(cuid())
  name         String
  title        String
  organization String
  bio          String?
  linkedinUrl  String?         @map("linkedin_url")
  website      String?
  createdAt    DateTime        @default(now()) @map("created_at")
  pages        KnowledgePage[]

  @@map("knowledge_authors")
}

model ImmigrationSource {
  id             String          @id @default(cuid())
  name           String
  sourceType     String          @map("source_type")
  url            String          @unique
  country        String          @default("Indonesia")
  authorityLevel String          @map("authority_level")
  createdAt      DateTime        @default(now()) @map("created_at")
  pages          KnowledgePage[] @relation("PageSources")

  @@map("immigration_sources")
}

model AIContentQuality {
  id              String        @id @default(cuid())
  knowledgePageId String        @unique @map("knowledge_page_id")
  wordCount       Int           @map("word_count")
  readability     Float
  seoScore        Float         @map("seo_score")
  semanticScore   Float         @map("semantic_score")
  uniqueness      Float         @map("uniqueness_score")
  overallScore    Float         @map("overall_score")
  createdAt       DateTime      @default(now()) @map("created_at")
  knowledgePage   KnowledgePage @relation(fields: [knowledgePageId], references: [id], onDelete: Cascade)

  @@map("ai_content_quality")
}

model Addon {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  description String
  shortDesc   String?
  price       Decimal  @db.Decimal(10, 2)
  category    String   @default("General")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("addons")
}

model GlobalSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  isEnabled Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("global_settings")
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}
